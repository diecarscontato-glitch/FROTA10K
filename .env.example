# ===========================================
# FROTA10K - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# --- Banco de Dados (Neon PostgreSQL) ---
# Pegue essas URLs no painel do Neon (https://console.neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- NextAuth ---
# Gere com: openssl rand -base64 32
AUTH_SECRET="gere-um-segredo-aleatorio-aqui"

# URL do site (mude para a URL da Vercel em produção)
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Crie em: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="seu-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="seu-google-client-secret"
